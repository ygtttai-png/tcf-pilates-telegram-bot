TELEGRAM_BOT_TOKEN=123456789:telegram_bot_tokeniniz
TELEGRAM_CHAT_ID=123456789

# Upstash Redis REST bilgileri. Vercel KV kullanıyorsanız KV_* değerleri de desteklenir.
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=upstash_rest_tokeniniz

# İsteğe bağlı: route'u manuel çağrılara karşı korumak için kullanılır.
CRON_SECRET=uzun_rastgele_bir_deger

# İlk çalıştırmada mevcut son 10 post içindeki eşleşmeleri bildirmek için true yapın.
# Varsayılan false: ilk çalıştırma sadece mevcut son post id'sini başlangıç noktası yapar.
NOTIFY_EXISTING_ON_FIRST_RUN=false
